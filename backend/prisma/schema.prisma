generator client {
  provider = "prisma-client-js"
}

datasource db {
  // PostgreSQL SIEMPRE — local y producción. NO cambiar a "sqlite" y commitear:
  // el hook pre-commit y el CI bloquean cualquier commit con provider sqlite.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id   String @id @default(cuid())
  name String
  spv  String
  holding          String
  address          String
  county           String
  hoa              String?
  parcelId         String?
  // Physical
  lotAcres         Float?
  sfHeated         Int     @default(2400)
  sfGarage         Int     @default(0)
  sfPorches        Int     @default(0)
  bedrooms         Int     @default(3)
  bathrooms        String  @default("2.5")
  architecturalPlan String?
  foundationType   String?
  // Permits
  permitNumber     String?
  permitIssued     DateTime?
  permitExpires    DateTime?
  inspectorPhone   String?
  hoaPhone         String?
  // GC
  gcName           String?
  gcPhone          String?
  gcLicense        String?
  gcEmail          String?
  // Financing
  lender           String?
  loanNumber       String?
  loanAmount       Float   @default(0)
  day1Disbursement Float   @default(0)
  interestReserve  Float   @default(0)
  holdback         Float   @default(0)
  interestRate     Float   @default(0.085)
  loanTermMonths   Int     @default(18)
  settlementDate   DateTime?
  cashAtSettlement Float   @default(0)
  closingCosts     Float   @default(0)
  contractSalesPrice Float @default(0)
  settlementAgent  String?
  // Valuation
  arv              Float   @default(0)
  constructionBudget Float @default(0)
  // Inspector
  trinityName      String?
  trinityPhone     String?
  trinityEmail     String?
  // Target
  targetCompletionDate DateTime?
  startDate        DateTime?
  // Realtor
  realtorName      String?
  realtorBrokerage String?
  realtorPhone     String?
  realtorEmail     String?
  listingCommission Float  @default(0.03)
  buyerCommission  Float   @default(0.03)
  targetListingPrice Float @default(0)
  expectedPricePerSqft Float @default(0)  // Manual: precio $/sqft esperado para proyecciones
  // Benchmarks
  contingencyPct   Float   @default(0.08)
  targetMarginPct  Float   @default(0.20)
  benchmarkSfTarget Float  @default(220)
  // Documentos financieros (URLs + nombres originales para auditoría)
  loiUrl             String?           // Letter of Intent / Acceptance of Offer / Offer Letter
  loiName            String?
  approvalLetterUrl  String?           // Carta de aprobación / commitment letter del lender
  approvalLetterName String?
  hudUrl             String?           // HUD-1 / Closing Disclosure
  hudName            String?
  otrosFinancieroUrl  String?          // "Otros" - genérico (puede ser cualquier doc adicional)
  otrosFinancieroName String?
  // Excel general del lender para la sección DRAWS. Complementa y VALIDA los PDF
  // de cada draw (lleva los totales del lender). NO crea aprobaciones de budget:
  // esas siguen viniendo solo del PDF de aprobación de cada draw (delta correcto).
  drawsExcelUrl       String?
  drawsExcelName      String?
  // Cómo reporta el lender los valores de cada draw (se adapta a cada lender):
  //   ACUMULADO   = cada draw trae el total corrido (incluye draws anteriores) — ej. Trinity
  //   INCREMENTAL = cada draw trae SOLO lo nuevo de ese draw
  // Rige el cálculo del delta por ítem y los totales, para que sea exacto sin adivinar.
  drawValuesMode      String   @default("ACUMULADO")
  // Datos extraídos del LOI (para CFO dashboard)
  loiSalePrice       Float?
  loiOfferDate       DateTime?
  loiExpectedClose   DateTime?
  loiEarnestMoney    Float?

  // Foto de referencia del proyecto (identificación visual en tarjetas y switcher)
  photoUrl   String?
  photoName  String?

  // Seguros del proyecto (Lote A): builder's risk + liability del GC
  builderRiskCarrier   String?
  builderRiskPolicyNum String?
  builderRiskExpiresAt DateTime?
  builderRiskUrl       String?
  builderRiskName      String?
  gcLiabilityExpiresAt DateTime?

  // Empresa (LLC) del organigrama administrativo responsable de este proyecto.
  // SetNull: borrar la empresa NO afecta el proyecto técnico.
  admCompanyId Int?
  admCompany   AdmCompany? @relation("CompanyTechProjects", fields: [admCompanyId], references: [id], onDelete: SetNull)

  phases       Phase[]
  draws        Draw[]
  changeOrders ChangeOrder[]
  punchItems   PunchListItem[]
  partners    Partner[]
  providers   Provider[]
  notes       Note[]
  files       ProjectFile[]
  inspections   Inspection[]
  tasks         Task[]
  budgetLines   BudgetLine[]
  subcontracts  SubcontractorContract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Phase {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code      String
  name      String
  groupName String
  order     Int
  // Enlace fase ↔ Construction Budget: uno o varios divCode de BudgetLine
  // (coma-separados). Se auto-completa por nombre/código y es editable.
  // Habilita la comparativa por fase: ejecutado vs presupuestado del budget.
  budgetDivCode String?
  items     Item[]
}

model Item {
  id                 String         @id @default(cuid())
  phaseId            String
  phase              Phase          @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  itemCode           String
  activity           String
  description        String?
  responsable        String?
  unit               String?
  esNA               Boolean        @default(false)
  completado         Boolean        @default(false)
  quantity           Float?         // cantidad en la unidad (para precios de referencia por unidad)
  valorPresupuestado Float          @default(0)
  // valorEjecutadoBase = valor propio de la actividad (lo que edita el usuario).
  // valorEjecutado = valorEjecutadoBase + Σ subactividades (roll-up guardado).
  // Así las subactividades SUMAN al valor de la actividad, no lo reemplazan, y
  // fases/dashboard/alertas (que leen valorEjecutado) reflejan el total.
  valorEjecutadoBase Float          @default(0)
  valorEjecutado     Float          @default(0)
  providerId         String?
  provider           Provider?      @relation(fields: [providerId], references: [id], onDelete: SetNull)
  estado             String         @default("PENDIENTE")
  fechaInicioReal    DateTime?
  fechaFinReal       DateTime?
  observaciones      String?
  order              Int
  // Asociación actividad ↔ línea del Construction Budget (opcional).
  // Permite comparar el gasto real de la actividad contra lo presupuestado en el
  // budget del lender aunque los nombres no coincidan. SetNull: si se borra la
  // línea del budget, la actividad queda sin asociar pero NO se pierde.
  budgetLineId       String?
  budgetLine         BudgetLine?    @relation("ItemBudgetLink", fields: [budgetLineId], references: [id], onDelete: SetNull)
  documents          ItemDocument[]
  subactivities      SubActivity[]
  finMovements       FinMovement[]  @relation("MovementTechItem")
}

// Subactividades de una actividad (Item) de Ejecución.
// El "valor" es EJECUTADO (gastado). Cuando una actividad tiene subactividades,
// su Item.valorEjecutado = suma de las subactividades (roll-up guardado en el
// backend), de modo que fases, dashboard y alertas lo reflejan sin cambios.
model SubActivity {
  id             String   @id @default(cuid())
  itemId         String
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  description    String
  valorEjecutado Float    @default(0)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  // Control administrativo por subactividad (cronograma + auditoría):
  fecha          DateTime? // cuándo se ejecutó / pagó
  responsable    String?   // quién lo hizo (persona o contratista)
  observaciones  String?
  // Soporte documental (invoice / equivalente) subido a Cloudinary
  invoiceUrl     String?
  invoiceName    String?
  // Proveedor/contratista del catálogo global — alimenta el récord por
  // proveedor en la sección Proveedores (historial de servicios y pagos).
  providerId     String?
  provider       Provider? @relation("SubActivityProvider", fields: [providerId], references: [id], onDelete: SetNull)
  finMovement    FinMovement? @relation("MovementTechSub")
}

model Draw {
  id                  String    @id @default(cuid())
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  drawNumber          Int
  fechaSolicitud      DateTime?
  fechaInspeccion     DateTime?
  fechaWire           DateTime?
  montoSolicitado     Float     @default(0)
  elegibleTrinity     Float     @default(0)
  porcentajeFunded    Float     @default(0)
  netWire             Float     @default(0)
  upbPre              Float     @default(0)
  upbPost             Float     @default(0)
  saldoHoldback       Float     @default(0)
  notas               String?
  pdfUrl              String?
  estado              String    @default("EMPTY")
  // Documentos requeridos por draw
  invoiceLenderUrl    String?   // factura entregada al lender ANTES de inspección
  invoiceLenderName   String?
  lenderApprovalUrl   String?   // documento devuelto por el lender DESPUÉS de inspección
  lenderApprovalName  String?
  lenderExcelUrl      String?   // tabla Excel del lender por draw
  lenderExcelName     String?
  contributions       DrawLineContribution[]
}

// Trazabilidad Draw→BudgetLine: cuánto aportó este draw a cada item del construction budget.
// valorAprobado de cada BudgetLine = SUM(deltaAmount) de todas sus contribuciones.
// Borrar un draw o su APPROVAL pdf elimina las contribuciones por cascade y dispara
// recálculo del valorAprobado — así el budget refleja siempre los draws vivos.
model DrawLineContribution {
  id            String     @id @default(cuid())
  drawId        String
  draw          Draw       @relation(fields: [drawId], references: [id], onDelete: Cascade)
  budgetLineId  String
  budgetLine    BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)
  itemCode      String
  deltaAmount   Float
  createdAt     DateTime   @default(now())

  @@unique([drawId, budgetLineId])
  @@index([budgetLineId])
}

model Partner {
  id            String  @id @default(cuid())
  projectId     String
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  ownershipPct  Float
  capitalAporte Float   @default(0)
  phone         String?
  email         String?
  order         Int
}

model Provider {
  id           String          @id @default(cuid())
  // GLOBAL (R2): projectId ahora es OPCIONAL. null = proveedor del catálogo
  // general del holding, usable en todos los proyectos. Los existentes
  // conservan su projectId (siguen visibles globalmente).
  projectId    String?
  project      Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  type         String?           // categoría libre (puede ser "Otro: lo que sea")
  phoneCountry String?           @default("+1")   // código país, default USA
  phone        String?
  email        String?
  license      String?
  address      String?
  notes        String?
  // COI — Certificate of Insurance (Lote A): vencimiento alertado en /alerts
  insuranceCarrier String?
  coiUrl           String?
  coiName          String?
  coiExpiresAt     DateTime?
  items        Item[]
  quotes       ProviderQuote[]
  documents    ProviderDocument[]
  contracts    SubcontractorContract[]
  invoiceDocs  ItemDocument[] @relation("InvoiceProvider")
  subactivities SubActivity[] @relation("SubActivityProvider")
}

model ProviderDocument {
  id          String    @id @default(cuid())
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  type        String    @default("OTRO")  // SEGURO | COTIZACION | FACTURA | CONTRATO | LICENCIA | W9 | OTRO
  name        String
  amount      Float?
  fileUrl     String?
  mimetype    String?
  size        Int?
  notes       String?
  createdAt   DateTime  @default(now())
}

model ProviderQuote {
  id          String    @id @default(cuid())
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  description String
  amount      Float     @default(0)
  date        DateTime?
  fileUrl     String?
  notes       String?
  createdAt   DateTime  @default(now())
}

model Note {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectFile {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  category  String?    // categoría legacy (Contrato, Permiso, etc.)
  kind      String?    // categoría del checklist documental (planos, survey, etc.) — ver lib/projectDocChecklist.ts
  url       String
  mimetype  String?    // ej. application/pdf, image/jpeg
  size      Int?       // bytes
  createdAt DateTime @default(now())
}

model Inspection {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbs             String
  tipo            String
  prerrequisitos  String?
  // T2: checklist estructurado de prerequisitos [{label, done}] en JSON.
  // "prerrequisitos" (texto libre) se conserva como descripción legacy.
  prereqs         String?
  fase            String?
  fechaSolicitada DateTime?
  fechaRealizada  DateTime?
  resultado       String?
  estado          String    @default("PENDIENTE")
  observaciones   String?
  order           Int
}

model BudgetLine {
  id              String  @id @default(cuid())
  projectId       String
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  divCode         String
  divName         String
  itemCode        String
  description     String
  unit            String  @default("LS")
  quantity        Float?  // cantidad en la unidad (para precios de referencia por unidad)
  vendor          String?
  valorInicial    Float   @default(0)
  valorPresentado Float   @default(0)
  valorAprobado   Float   @default(0)
  pagadoSubs      Float   @default(0)
  order           Int     @default(0)
  contributions   DrawLineContribution[]
  changeOrders    ChangeOrder[]
  // Actividades de Ejecución asociadas a esta línea del budget (seguimiento
  // presupuesto-lender vs gasto real, aunque los nombres no coincidan).
  linkedItems     Item[]  @relation("ItemBudgetLink")
}

model Task {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tipo          String    @default("TAREA")   // TAREA | NOTA (Notas fusionadas en Tareas)
  title         String
  responsable   String?
  responsableEmail String?
  done          Boolean   @default(false)
  completedAt   DateTime?
  priority      String    @default("NORMAL")
  dueDate       DateTime?
  notes         String?
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ItemDocument {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      String   @default("OTRO")
  name      String
  vendor    String?
  // R2: proveedor del catálogo (para récord de facturación por proveedor/proyecto)
  providerId String?
  provider   Provider? @relation("InvoiceProvider", fields: [providerId], references: [id], onDelete: SetNull)
  amount    Float?
  fileUrl   String?
  notes     String?
  createdAt DateTime @default(now())
}

model PriceRef {
  id          String   @id @default(cuid())
  category    String
  code        String?
  description String
  unit        String   @default("LS")
  priceLow    Float    @default(0)
  priceHigh   Float    @default(0)
  source      String?
  region      String?  @default("SC Upstate")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Subcontratistas: contrato firmado + alcance + calendario de pagos por hito.
model SubcontractorContract {
  id              String                 @id @default(cuid())
  providerId      String
  provider        Provider               @relation(fields: [providerId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractValue   Float                  @default(0)
  scopeDetails    String?
  startDate       DateTime?
  endDate         DateTime?
  status          String                 @default("ACTIVO") // ACTIVO | COMPLETADO | CANCELADO
  contractUrl     String?
  contractName    String?
  notes           String?
  paymentSchedule SubcontractorPayment[]
  changeOrders    ChangeOrder[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model SubcontractorPayment {
  id            String                @id @default(cuid())
  contractId    String
  contract      SubcontractorContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  milestoneDesc String
  amount        Float                 @default(0)
  dueDate       DateTime?
  paidDate      DateTime?
  status        String                @default("PENDIENTE") // PENDIENTE | PAGADO | RETENIDO
  notes         String?
  // Lien waiver (Lote A): en SC un sub no pagado puede poner mechanic's lien.
  // Para marcar PAGADO se exige waiver adjunto O una excepción explícita con razón.
  lienWaiverUrl   String?
  lienWaiverName  String?
  lienWaiverAt    DateTime?
  waiverException String?
  createdAt     DateTime              @default(now())
}


// Change Orders (Lote A): control formal de cambios de alcance.
// Registra qué cambió, cuánto cuesta (+/-), cuántos días agrega y quién aprobó.
// El presupuesto ajustado del proyecto = budget original + SUM(costDelta de APROBADOS).
model ChangeOrder {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  coNumber     Int      // consecutivo por proyecto (CO-1, CO-2...)
  title        String
  description  String?
  reason       String   @default("OTRO") // CONDICION_OCULTA | ERROR_DISENO | SOLICITUD_PROPIETARIO | CODIGO | CLIMA | OTRO
  costDelta    Float    @default(0)      // positivo = sobrecosto, negativo = crédito
  daysDelta    Int      @default(0)      // días que agrega (+) o ahorra (-) al cronograma
  status       String   @default("BORRADOR") // BORRADOR | APROBADO | RECHAZADO
  requestedBy  String?  // quién lo origina (GC, sub, propietario, inspector)
  approvedBy   String?
  approvedAt   DateTime?
  contractId   String?
  contract     SubcontractorContract? @relation(fields: [contractId], references: [id])
  budgetLineId String?
  budgetLine   BudgetLine? @relation(fields: [budgetLineId], references: [id])
  docUrl       String?  // soporte firmado (PDF/foto)
  docName      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, coNumber])
  @@index([projectId])
}

// Punch List (Lote B): cierre de obra (Etapa 9) con responsable, evidencia y estado.
// Flujo: ABIERTO -> CORREGIDO (el responsable reporta) -> VERIFICADO (tú confirmas con evidencia).
model PunchListItem {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  location    String?  // ambiente: "Cocina", "Baño master", "Exterior norte"...
  responsable String?  // quién debe corregirlo (GC, sub específico)
  severity    String   @default("MEDIA") // BAJA | MEDIA | ALTA (bloquea cierre)
  status      String   @default("ABIERTO") // ABIERTO | CORREGIDO | VERIFICADO
  notes       String?
  photoUrl    String?  // evidencia (foto del defecto o de la corrección)
  photoName   String?
  dueDate     DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

// ============================================================
// MODULO FINANCIERO - Modelos prefijados con "Fin" para convivir
// con los modelos del modulo tecnico (Project, Partner, Provider)
// en la misma base de datos. Tablas SQL prefijadas con fin_ via @@map.
// ============================================================
// Schema del MÓDULO FINANCIERO — cliente Prisma separado
// Comparte la misma DB de PostgreSQL en producción pero usa tablas prefijadas con `fin_`
// para evitar colisión con los modelos del módulo técnico (FinProject, FinPartner, FinProvider).

// ============================================================
// CATÁLOGOS MAESTROS
// ============================================================

model FinSPV {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  accounts  FinAccount[]
  projects  FinProject[]
  // Vínculo con el módulo administrativo: cada SPV puede tener su empresa
  // en el organigrama corporativo (1:1, opcional, no destructivo)
  admCompany AdmCompany?

  @@map("fin_spv")
}

model FinAccount {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  bank          String
  yearsActive   String?
  initialBalance Float   @default(0)
  reportedBalance Float  @default(0)
  currentBalance Float   @default(0)
  accountNumber  String?
  routingNumber  String?
  address        String?
  type          String   @default("operativa")
  active        Boolean  @default(true)
  notes         String?
  spvId         Int?
  spv           FinSPV?     @relation(fields: [spvId], references: [id])
  createdAt     DateTime @default(now())
  movementsFrom FinMovement[] @relation("AccountFrom")
  movementsTo   FinMovement[] @relation("AccountTo")
  statements    FinBankStatement[]

  @@map("fin_account")
}

model FinPartner {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  fullName  String
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  movements FinMovement[]
  capitalContribs FinCapitalContribution[]
  nonBankContribs FinNonBankContribution[]

  @@map("fin_partner")
}

model FinLender {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  type          String   @default("FinLender")
  contactName   String?
  email         String?
  phone         String?
  notes         String?
  createdAt     DateTime @default(now())
  loans         FinLoan[]
  movements     FinMovement[]

  @@map("fin_lender")
}

model FinProvider {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  type      String?
  contactName String?
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  movements FinMovement[]

  @@map("fin_provider")
}

model FinExpenseCategory {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  group     String?
  isCorporate Boolean @default(false)
  // Bucket fiscal US para el paquete anual del contador (Lote C).
  // Si es null se infiere por nombre/grupo (ver finance/lib/taxBuckets.ts).
  taxBucket String?
  notes     String?
  createdAt DateTime @default(now())
  movements FinMovement[]

  @@map("fin_expense_category")
}

model FinIncomeOrigin {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  movements FinMovement[]

  @@map("fin_income_origin")
}

// ============================================================
// PROYECTOS DEL PORTAFOLIO FINANCIERO
// ============================================================

model FinProject {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  line          String?
  model         String?
  status        String   @default("Enlistado")
  spvId         Int?
  spv           FinSPV?     @relation(fields: [spvId], references: [id])
  address       String?
  purchasePrice Float    @default(0)
  arv           Float    @default(0)
  expectedCost  Float    @default(0)
  cashIn        Float    @default(0)
  notes         String?
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  movements     FinMovement[]
  capitalContribs FinCapitalContribution[]
  loans         FinLoan[]
  nonBankContribs FinNonBankContribution[]
  documents     FinProjectDocument[]

  @@map("fin_project")
}

// ============================================================
// NÚCLEO: MOVIMIENTOS BANCARIOS
// ============================================================

model FinMovement {
  id              Int      @id @default(autoincrement())
  date            DateTime
  type            String
  amount          Float
  concept         String
  notes           String?

  accountId       Int
  account         FinAccount  @relation("AccountFrom", fields: [accountId], references: [id])
  destAccountId   Int?
  destAccount     FinAccount? @relation("AccountTo", fields: [destAccountId], references: [id])

  categoryId      Int?
  category        FinExpenseCategory? @relation(fields: [categoryId], references: [id])
  originId        Int?
  origin          FinIncomeOrigin? @relation(fields: [originId], references: [id])
  providerId      Int?
  provider        FinProvider? @relation(fields: [providerId], references: [id])

  isEquity        Boolean  @default(false)
  partnerId       Int?
  partner         FinPartner? @relation(fields: [partnerId], references: [id])

  isLoan          Boolean  @default(false)
  lenderId        Int?
  lender          FinLender?  @relation(fields: [lenderId], references: [id])
  isLoanRepayment Boolean  @default(false)
  loanId          Int?
  loan            FinLoan?    @relation(fields: [loanId], references: [id])

  projectId       Int?
  project         FinProject? @relation(fields: [projectId], references: [id])

  isIntercompany  Boolean  @default(false)
  linkedMovementId Int?    @unique
  linkedMovement   FinMovement? @relation("IntercompanyLink", fields: [linkedMovementId], references: [id])
  linkedFrom       FinMovement? @relation("IntercompanyLink")

  hasSupport      Boolean  @default(false)
  isReconciled    Boolean  @default(false)
  needsReview     Boolean  @default(false)
  reviewReason    String?

  // Comparación con extractos bancarios:
  //   "matched"   = movimiento manual coincide con línea de extracto (verde)
  //   "manual_only" = registrado manual pero no aparece en extracto (amarillo)
  //   "extract_only" = en extracto, falta registrar manualmente (rojo, se crea como needsReview)
  //   "pending"   = sin extracto cargado todavía (neutral)
  matchStatus     String   @default("pending")
  matchedLineId   Int?

  importSource    String?
  importRef       String?

  // ── ENGRANAJE CON EL MÓDULO TÉCNICO (opcional, no destructivo) ──
  // Un Egreso puede asociarse a una actividad (Item) de la obra. Al asociarlo,
  // el backend crea/actualiza una SubActivity espejo en esa actividad (misma
  // fecha, valor y concepto), de modo que el gasto queda registrado en AMBOS
  // módulos de una sola vez. techSubActivityId apunta a esa subactividad espejo
  // (gestionada por el backend, nunca editada por el usuario directamente).
  // SetNull: borrar la actividad u obra NO borra el movimiento financiero.
  techItemId        String?
  techItem          Item?        @relation("MovementTechItem", fields: [techItemId], references: [id], onDelete: SetNull)
  techSubActivityId String?      @unique
  techSubActivity   SubActivity? @relation("MovementTechSub", fields: [techSubActivityId], references: [id], onDelete: SetNull)

  documents       FinMovementDocument[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([accountId])
  @@index([projectId])
  @@index([partnerId])
  @@index([categoryId])
  @@index([type])
  @@index([techItemId])
  @@map("fin_movement")
}

// ============================================================
// CAPITALIZACIÓN
// ============================================================

model FinCapitalContribution {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  concept     String
  origin      String
  partnerId   Int
  partner     FinPartner  @relation(fields: [partnerId], references: [id])
  projectId   Int?
  project     FinProject? @relation(fields: [projectId], references: [id])
  destAccountCode String?
  notes       String?
  // Si la contribución se sincronizó automáticamente desde un movimiento
  // (Ingreso + isEquity), apunta al movimiento de origen. Permite mantener
  // 1-1 entre Movimiento equity y Capital: si el movimiento se borra/actualiza,
  // la contribución refleja el cambio.
  sourceMovementId Int? @unique
  createdAt   DateTime @default(now())

  @@map("fin_capital_contribution")
}

model FinLoan {
  id            Int      @id @default(autoincrement())
  date          DateTime
  amount        Float
  concept       String
  lenderId      Int
  lender        FinLender   @relation(fields: [lenderId], references: [id])
  projectId     Int?
  project       FinProject? @relation(fields: [projectId], references: [id])
  destAccountCode String?
  interestRate  Float?
  termMonths    Int?
  startDate     DateTime?
  endDate       DateTime?
  status        String   @default("activo")
  classification String?
  totalRepaid   Float    @default(0)
  notes         String?
  // Auto-sync 1-1 con un movimiento de Ingreso + isLoan + lenderId.
  // Si el movimiento se borra/actualiza, el préstamo refleja el cambio.
  sourceMovementId Int? @unique
  createdAt     DateTime @default(now())
  movements     FinMovement[]

  @@map("fin_loan")
}

model FinNonBankContribution {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  concept     String
  partnerId   Int
  partner     FinPartner  @relation(fields: [partnerId], references: [id])
  projectId   Int?
  project     FinProject? @relation(fields: [projectId], references: [id])
  notes       String?
  createdAt   DateTime @default(now())

  @@map("fin_nonbank_contribution")
}

// ============================================================
// DOCUMENTOS / SOPORTES
// ============================================================

model FinMovementDocument {
  id          Int      @id @default(autoincrement())
  movementId  Int
  movement    FinMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  publicId    String?
  mimetype    String?
  size        Int?
  kind        String?
  uploadedAt  DateTime @default(now())

  @@map("fin_movement_document")
}

model FinProjectDocument {
  id          Int      @id @default(autoincrement())
  projectId   Int
  project     FinProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  publicId    String?
  mimetype    String?
  size        Int?
  kind        String?
  uploadedAt  DateTime @default(now())

  @@map("fin_project_document")
}

// ============================================================
// EXTRACTOS BANCARIOS (RECONCILIACIÓN)
// ============================================================

model FinBankStatement {
  id          Int      @id @default(autoincrement())
  accountId   Int
  account     FinAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  openingBalance Float?
  closingBalance Float?
  filename    String?
  url         String?
  uploadedAt  DateTime @default(now())
  lines       FinBankStatementLine[]

  @@map("fin_bank_statement")
}

model FinBankStatementLine {
  id              Int      @id @default(autoincrement())
  statementId     Int
  statement       FinBankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  date            DateTime
  description     String
  amount          Float
  type            String
  matchStatus     String   @default("unmatched")
  matchedMovementId Int?
  diffNote        String?

  @@map("fin_bank_statement_line")
}

// ============================================================
// AUDITORÍA / ALERTAS
// ============================================================

model FinActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  detail    String?
  user      String?
  createdAt DateTime @default(now())

  @@map("fin_activity_log")
}

// ============================================================
// ============================================================
// MÓDULO ADMINISTRATIVO — GOBIERNO CORPORATIVO
// Modelos prefijados con `Adm`, tablas con prefijo `adm_`
// (misma convención que el módulo financiero `Fin` / `fin_`)
// ============================================================
// ============================================================

// Empresa del grupo: la holding y sus subsidiarias.
// parentId construye el organigrama (holding arriba, subsidiarias abajo).
// finSpvId vincula (opcional, 1:1) con el SPV del módulo financiero —
// una sola fuente de verdad, sin duplicar empresas.
model AdmCompany {
  id               Int       @id @default(autoincrement())
  name             String
  legalName        String?
  role             String    @default("SUBSIDIARY_OWNER") // HOLDING | PROPERTY_MANAGER | SUBSIDIARY_OWNER | OTHER
  entityType       String?   @default("LLC")
  stateOfFormation String?
  ein              String?
  formationDate    DateTime?
  registeredAgent  String?
  address          String?
  status           String    @default("ACTIVE") // ACTIVE | INACTIVE | DISSOLVED
  notes            String?

  parentId Int?
  parent   AdmCompany?  @relation("AdmCompanyHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children AdmCompany[] @relation("AdmCompanyHierarchy")

  finSpvId Int?    @unique
  finSpv   FinSPV? @relation(fields: [finSpvId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  documents    AdmDocument[]
  requirements AdmRequirement[]
  tasks        AdmTask[]
  // Proyectos del módulo TÉCNICO a cargo de esta LLC (carga operativa)
  techProjects Project[]    @relation("CompanyTechProjects")

  @@map("adm_company")
}

// Catálogo de tipos documentales del due diligence corporativo
// (articles of organization, operating agreement, EIN, annual report,
// good standing, pólizas, certificados bancarios, hojas de vida, etc.)
model AdmDocType {
  id              Int     @id @default(autoincrement())
  code            String  @unique
  name            String
  category        String  // FORMACION | FISCAL | BANCARIO | SEGUROS | CUMPLIMIENTO | PROPIEDAD | PERSONAL | LEGAL | OTRO
  description     String?
  defaultRequired Boolean @default(false) // se exige por defecto a toda empresa
  hasExpiry       Boolean @default(false) // requiere fecha de vencimiento/renovación
  renewalMonths   Int?    // frecuencia típica de renovación (12 = anual)
  sortOrder       Int     @default(0)

  documents    AdmDocument[]
  requirements AdmRequirement[]

  @@map("adm_doc_type")
}

// Documento del expediente digital de una empresa (archivo en Cloudinary)
model AdmDocument {
  id         Int         @id @default(autoincrement())
  companyId  Int
  company    AdmCompany  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  docTypeId  Int?
  docType    AdmDocType? @relation(fields: [docTypeId], references: [id], onDelete: SetNull)
  filename   String
  url        String
  publicId   String?
  mimetype   String?
  size       Int?
  issueDate  DateTime?
  expiryDate DateTime? // motor de alertas: vencido / por vencer
  notes      String?
  uploadedAt DateTime  @default(now())

  @@map("adm_document")
}

// Requisito documental por empresa (checklist de cumplimiento):
// qué tipos de documento DEBE tener al día cada empresa.
model AdmRequirement {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   AdmCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  docTypeId Int
  docType   AdmDocType @relation(fields: [docTypeId], references: [id], onDelete: Cascade)
  required  Boolean    @default(true)
  notes     String?

  @@unique([companyId, docTypeId])
  @@map("adm_requirement")
}

// Tarea administrativa (opcionalmente ligada a una empresa y/o a un socio)
model AdmTask {
  id          Int         @id @default(autoincrement())
  companyId   Int?
  company     AdmCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  personId    Int?
  person      AdmPerson?  @relation(fields: [personId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  priority    String      @default("media") // alta | media | baja
  status      String      @default("pendiente") // pendiente | en_progreso | completada
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  @@map("adm_task")
}

// ============================================================
// SOCIOS Y COLABORADORES — carpeta documental personal
// ============================================================
// Cada persona tiene su propio checklist de documentos (requisitos con
// categoría y nombre libres), su expediente de archivos en Cloudinary y
// sus tareas/pendientes. El cumplimiento se DERIVA de datos reales,
// igual que el semáforo de empresas (nunca queda desactualizado).
model AdmPerson {
  id       Int     @id @default(autoincrement())
  name     String
  role     String  @default("SOCIO") // SOCIO | COLABORADOR | OTRO
  position String? // cargo dentro del grupo
  email    String?
  phone    String?
  idNumber String? // cédula / pasaporte / SSN-ITIN
  status   String  @default("ACTIVO") // ACTIVO | INACTIVO
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  requirements AdmPersonRequirement[]
  documents    AdmPersonDocument[]
  tasks        AdmTask[]

  @@map("adm_person")
}

// Requisito documental de una persona: nombre del archivo esperado +
// categoría libre (el usuario crea las categorías que necesite).
model AdmPersonRequirement {
  id        Int       @id @default(autoincrement())
  personId  Int
  person    AdmPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  name      String
  category  String    @default("GENERAL")
  hasExpiry Boolean   @default(false)
  required  Boolean   @default(true)
  sortOrder Int       @default(0)
  notes     String?

  documents AdmPersonDocument[]

  @@map("adm_person_requirement")
}

// Archivo de la carpeta personal (Cloudinary), opcionalmente ligado
// a un requisito del checklist.
model AdmPersonDocument {
  id            Int                   @id @default(autoincrement())
  personId      Int
  person        AdmPerson             @relation(fields: [personId], references: [id], onDelete: Cascade)
  requirementId Int?
  requirement   AdmPersonRequirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  filename      String
  url           String
  publicId      String?
  mimetype      String?
  size          Int?
  issueDate     DateTime?
  expiryDate    DateTime?
  notes         String?
  uploadedAt    DateTime              @default(now())

  @@map("adm_person_document")
}

