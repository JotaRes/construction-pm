generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id   String @id @default(cuid())
  name String
  spv  String
  holding          String
  address          String
  county           String
  hoa              String?
  parcelId         String?
  // Physical
  lotAcres         Float?
  sfHeated         Int     @default(2400)
  sfGarage         Int     @default(0)
  sfPorches        Int     @default(0)
  bedrooms         Int     @default(3)
  bathrooms        String  @default("2.5")
  architecturalPlan String?
  foundationType   String?
  // Permits
  permitNumber     String?
  permitIssued     DateTime?
  permitExpires    DateTime?
  inspectorPhone   String?
  hoaPhone         String?
  // GC
  gcName           String?
  gcPhone          String?
  gcLicense        String?
  gcEmail          String?
  // Financing
  lender           String?
  loanNumber       String?
  loanAmount       Float   @default(0)
  day1Disbursement Float   @default(0)
  interestReserve  Float   @default(0)
  holdback         Float   @default(0)
  interestRate     Float   @default(0.085)
  loanTermMonths   Int     @default(18)
  settlementDate   DateTime?
  cashAtSettlement Float   @default(0)
  closingCosts     Float   @default(0)
  settlementAgent  String?
  // Valuation
  arv              Float   @default(0)
  constructionBudget Float @default(0)
  // Inspector
  trinityName      String?
  trinityPhone     String?
  trinityEmail     String?
  // Target
  targetCompletionDate DateTime?
  startDate        DateTime?
  // Realtor
  realtorName      String?
  realtorBrokerage String?
  realtorPhone     String?
  realtorEmail     String?
  listingCommission Float  @default(0.03)
  buyerCommission  Float   @default(0.03)
  targetListingPrice Float @default(0)
  // Benchmarks
  contingencyPct   Float   @default(0.08)
  targetMarginPct  Float   @default(0.20)
  benchmarkSfTarget Float  @default(220)

  phases      Phase[]
  draws       Draw[]
  partners    Partner[]
  providers   Provider[]
  notes       Note[]
  files       ProjectFile[]
  inspections   Inspection[]
  tasks         Task[]
  budgetLines   BudgetLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Phase {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code      String
  name      String
  groupName String
  order     Int
  items     Item[]
}

model Item {
  id                 String         @id @default(cuid())
  phaseId            String
  phase              Phase          @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  itemCode           String
  activity           String
  description        String?
  responsable        String?
  unit               String?
  esNA               Boolean        @default(false)
  completado         Boolean        @default(false)
  valorPresupuestado Float          @default(0)
  valorEjecutado     Float          @default(0)
  providerId         String?
  provider           Provider?      @relation(fields: [providerId], references: [id], onDelete: SetNull)
  estado             String         @default("PENDIENTE")
  fechaInicioReal    DateTime?
  fechaFinReal       DateTime?
  observaciones      String?
  order              Int
  documents          ItemDocument[]
}

model Draw {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  drawNumber       Int
  fechaSolicitud   DateTime?
  fechaInspeccion  DateTime?
  fechaWire        DateTime?
  montoSolicitado  Float     @default(0)
  elegibleTrinity  Float     @default(0)
  porcentajeFunded Float     @default(0)
  netWire          Float     @default(0)
  upbPre           Float     @default(0)
  upbPost          Float     @default(0)
  saldoHoldback    Float     @default(0)
  notas            String?
  pdfUrl           String?
  estado           String    @default("EMPTY")
}

model Partner {
  id            String  @id @default(cuid())
  projectId     String
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  ownershipPct  Float
  capitalAporte Float   @default(0)
  phone         String?
  email         String?
  order         Int
}

model Provider {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  type      String?
  phone     String?
  email     String?
  license   String?
  notes     String?
  items     Item[]
  quotes    ProviderQuote[]
}

model ProviderQuote {
  id          String    @id @default(cuid())
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  description String
  amount      Float     @default(0)
  date        DateTime?
  fileUrl     String?
  notes       String?
  createdAt   DateTime  @default(now())
}

model Note {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectFile {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  category  String?
  url       String
  createdAt DateTime @default(now())
}

model Inspection {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbs             String
  tipo            String
  prerrequisitos  String?
  fase            String?
  fechaSolicitada DateTime?
  fechaRealizada  DateTime?
  resultado       String?
  estado          String    @default("PENDIENTE")
  observaciones   String?
  order           Int
}

model BudgetLine {
  id              String  @id @default(cuid())
  projectId       String
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  divCode         String
  divName         String
  itemCode        String
  description     String
  unit            String  @default("LS")
  vendor          String?
  valorInicial    Float   @default(0)
  valorPresentado Float   @default(0)
  valorAprobado   Float   @default(0)
  pagadoSubs      Float   @default(0)
  order           Int     @default(0)
}

model Task {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  responsable  String?
  done         Boolean   @default(false)
  priority     String    @default("NORMAL")
  dueDate      DateTime?
  notes        String?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ItemDocument {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      String   @default("OTRO")
  name      String
  vendor    String?
  amount    Float?
  fileUrl   String?
  notes     String?
  createdAt DateTime @default(now())
}

model PriceRef {
  id          String   @id @default(cuid())
  category    String
  code        String?
  description String
  unit        String   @default("LS")
  priceLow    Float    @default(0)
  priceHigh   Float    @default(0)
  source      String?
  region      String?  @default("SC Upstate")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


// ============================================================
// MODULO FINANCIERO - Modelos prefijados con "Fin" para convivir
// con los modelos del modulo tecnico (Project, Partner, Provider)
// en la misma base de datos. Tablas SQL prefijadas con fin_ via @@map.
// ============================================================
// Schema del MÓDULO FINANCIERO — cliente Prisma separado
// Comparte la misma DB de PostgreSQL en producción pero usa tablas prefijadas con `fin_`
// para evitar colisión con los modelos del módulo técnico (FinProject, FinPartner, FinProvider).

// ============================================================
// CATÁLOGOS MAESTROS
// ============================================================

model FinSPV {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  accounts  FinAccount[]
  projects  FinProject[]

  @@map("fin_spv")
}

model FinAccount {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  bank          String
  yearsActive   String?
  initialBalance Float   @default(0)
  reportedBalance Float  @default(0)
  currentBalance Float   @default(0)
  accountNumber  String?
  routingNumber  String?
  address        String?
  type          String   @default("operativa")
  active        Boolean  @default(true)
  notes         String?
  spvId         Int?
  spv           FinSPV?     @relation(fields: [spvId], references: [id])
  createdAt     DateTime @default(now())
  movementsFrom FinMovement[] @relation("AccountFrom")
  movementsTo   FinMovement[] @relation("AccountTo")
  statements    FinBankStatement[]

  @@map("fin_account")
}

model FinPartner {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  fullName  String
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  movements FinMovement[]
  capitalContribs FinCapitalContribution[]
  nonBankContribs FinNonBankContribution[]

  @@map("fin_partner")
}

model FinLender {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  type          String   @default("FinLender")
  contactName   String?
  email         String?
  phone         String?
  notes         String?
  createdAt     DateTime @default(now())
  loans         FinLoan[]
  movements     FinMovement[]

  @@map("fin_lender")
}

model FinProvider {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  type      String?
  contactName String?
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  movements FinMovement[]

  @@map("fin_provider")
}

model FinExpenseCategory {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  group     String?
  isCorporate Boolean @default(false)
  notes     String?
  createdAt DateTime @default(now())
  movements FinMovement[]

  @@map("fin_expense_category")
}

model FinIncomeOrigin {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  movements FinMovement[]

  @@map("fin_income_origin")
}

// ============================================================
// PROYECTOS DEL PORTAFOLIO FINANCIERO
// ============================================================

model FinProject {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  line          String?
  model         String?
  status        String   @default("Enlistado")
  spvId         Int?
  spv           FinSPV?     @relation(fields: [spvId], references: [id])
  address       String?
  purchasePrice Float    @default(0)
  arv           Float    @default(0)
  expectedCost  Float    @default(0)
  cashIn        Float    @default(0)
  notes         String?
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  movements     FinMovement[]
  capitalContribs FinCapitalContribution[]
  loans         FinLoan[]
  nonBankContribs FinNonBankContribution[]
  documents     FinProjectDocument[]

  @@map("fin_project")
}

// ============================================================
// NÚCLEO: MOVIMIENTOS BANCARIOS
// ============================================================

model FinMovement {
  id              Int      @id @default(autoincrement())
  date            DateTime
  type            String
  amount          Float
  concept         String
  notes           String?

  accountId       Int
  account         FinAccount  @relation("AccountFrom", fields: [accountId], references: [id])
  destAccountId   Int?
  destAccount     FinAccount? @relation("AccountTo", fields: [destAccountId], references: [id])

  categoryId      Int?
  category        FinExpenseCategory? @relation(fields: [categoryId], references: [id])
  originId        Int?
  origin          FinIncomeOrigin? @relation(fields: [originId], references: [id])
  providerId      Int?
  provider        FinProvider? @relation(fields: [providerId], references: [id])

  isEquity        Boolean  @default(false)
  partnerId       Int?
  partner         FinPartner? @relation(fields: [partnerId], references: [id])

  isLoan          Boolean  @default(false)
  lenderId        Int?
  lender          FinLender?  @relation(fields: [lenderId], references: [id])
  isLoanRepayment Boolean  @default(false)
  loanId          Int?
  loan            FinLoan?    @relation(fields: [loanId], references: [id])

  projectId       Int?
  project         FinProject? @relation(fields: [projectId], references: [id])

  isIntercompany  Boolean  @default(false)
  linkedMovementId Int?    @unique
  linkedMovement   FinMovement? @relation("IntercompanyLink", fields: [linkedMovementId], references: [id])
  linkedFrom       FinMovement? @relation("IntercompanyLink")

  hasSupport      Boolean  @default(false)
  isReconciled    Boolean  @default(false)
  needsReview     Boolean  @default(false)
  reviewReason    String?

  // Comparación con extractos bancarios:
  //   "matched"   = movimiento manual coincide con línea de extracto (verde)
  //   "manual_only" = registrado manual pero no aparece en extracto (amarillo)
  //   "extract_only" = en extracto, falta registrar manualmente (rojo, se crea como needsReview)
  //   "pending"   = sin extracto cargado todavía (neutral)
  matchStatus     String   @default("pending")
  matchedLineId   Int?

  importSource    String?
  importRef       String?

  documents       FinMovementDocument[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([accountId])
  @@index([projectId])
  @@index([partnerId])
  @@index([categoryId])
  @@index([type])
  @@map("fin_movement")
}

// ============================================================
// CAPITALIZACIÓN
// ============================================================

model FinCapitalContribution {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  concept     String
  origin      String
  partnerId   Int
  partner     FinPartner  @relation(fields: [partnerId], references: [id])
  projectId   Int?
  project     FinProject? @relation(fields: [projectId], references: [id])
  destAccountCode String?
  notes       String?
  // Si la contribución se sincronizó automáticamente desde un movimiento
  // (Ingreso + isEquity), apunta al movimiento de origen. Permite mantener
  // 1-1 entre Movimiento equity y Capital: si el movimiento se borra/actualiza,
  // la contribución refleja el cambio.
  sourceMovementId Int? @unique
  createdAt   DateTime @default(now())

  @@map("fin_capital_contribution")
}

model FinLoan {
  id            Int      @id @default(autoincrement())
  date          DateTime
  amount        Float
  concept       String
  lenderId      Int
  lender        FinLender   @relation(fields: [lenderId], references: [id])
  projectId     Int?
  project       FinProject? @relation(fields: [projectId], references: [id])
  destAccountCode String?
  interestRate  Float?
  termMonths    Int?
  startDate     DateTime?
  endDate       DateTime?
  status        String   @default("activo")
  classification String?
  totalRepaid   Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  movements     FinMovement[]

  @@map("fin_loan")
}

model FinNonBankContribution {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  concept     String
  partnerId   Int
  partner     FinPartner  @relation(fields: [partnerId], references: [id])
  projectId   Int?
  project     FinProject? @relation(fields: [projectId], references: [id])
  notes       String?
  createdAt   DateTime @default(now())

  @@map("fin_nonbank_contribution")
}

// ============================================================
// DOCUMENTOS / SOPORTES
// ============================================================

model FinMovementDocument {
  id          Int      @id @default(autoincrement())
  movementId  Int
  movement    FinMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  publicId    String?
  mimetype    String?
  size        Int?
  kind        String?
  uploadedAt  DateTime @default(now())

  @@map("fin_movement_document")
}

model FinProjectDocument {
  id          Int      @id @default(autoincrement())
  projectId   Int
  project     FinProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  publicId    String?
  mimetype    String?
  size        Int?
  kind        String?
  uploadedAt  DateTime @default(now())

  @@map("fin_project_document")
}

// ============================================================
// EXTRACTOS BANCARIOS (RECONCILIACIÓN)
// ============================================================

model FinBankStatement {
  id          Int      @id @default(autoincrement())
  accountId   Int
  account     FinAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  openingBalance Float?
  closingBalance Float?
  filename    String?
  url         String?
  uploadedAt  DateTime @default(now())
  lines       FinBankStatementLine[]

  @@map("fin_bank_statement")
}

model FinBankStatementLine {
  id              Int      @id @default(autoincrement())
  statementId     Int
  statement       FinBankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  date            DateTime
  description     String
  amount          Float
  type            String
  matchStatus     String   @default("unmatched")
  matchedMovementId Int?
  diffNote        String?

  @@map("fin_bank_statement_line")
}

// ============================================================
// AUDITORÍA / ALERTAS
// ============================================================

model FinActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  detail    String?
  user      String?
  createdAt DateTime @default(now())

  @@map("fin_activity_log")
}

