// Schema del MÓDULO FINANCIERO — cliente Prisma separado
// Comparte la misma DB de PostgreSQL en producción pero usa tablas prefijadas con `fin_`
// para evitar colisión con los modelos del módulo técnico (Project, Partner, Provider).

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/finance-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL_FIN")
}

// ============================================================
// CATÁLOGOS MAESTROS
// ============================================================

model SPV {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  accounts  Account[]
  projects  Project[]

  @@map("fin_spv")
}

model Account {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  bank          String
  yearsActive   String?
  initialBalance Float   @default(0)
  reportedBalance Float  @default(0)
  type          String   @default("operativa")
  active        Boolean  @default(true)
  notes         String?
  spvId         Int?
  spv           SPV?     @relation(fields: [spvId], references: [id])
  createdAt     DateTime @default(now())
  movementsFrom Movement[] @relation("AccountFrom")
  movementsTo   Movement[] @relation("AccountTo")
  statements    BankStatement[]

  @@map("fin_account")
}

model Partner {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  fullName  String
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  movements Movement[]
  capitalContribs CapitalContribution[]
  nonBankContribs NonBankContribution[]

  @@map("fin_partner")
}

model Lender {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  type          String   @default("Lender")
  contactName   String?
  email         String?
  phone         String?
  notes         String?
  createdAt     DateTime @default(now())
  loans         Loan[]
  movements     Movement[]

  @@map("fin_lender")
}

model Provider {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  type      String?
  contactName String?
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  movements Movement[]

  @@map("fin_provider")
}

model ExpenseCategory {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  group     String?
  isCorporate Boolean @default(false)
  notes     String?
  createdAt DateTime @default(now())
  movements Movement[]

  @@map("fin_expense_category")
}

model IncomeOrigin {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  movements Movement[]

  @@map("fin_income_origin")
}

// ============================================================
// PROYECTOS DEL PORTAFOLIO FINANCIERO
// ============================================================

model Project {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  line          String?
  model         String?
  status        String   @default("Enlistado")
  spvId         Int?
  spv           SPV?     @relation(fields: [spvId], references: [id])
  address       String?
  purchasePrice Float    @default(0)
  arv           Float    @default(0)
  expectedCost  Float    @default(0)
  cashIn        Float    @default(0)
  notes         String?
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  movements     Movement[]
  capitalContribs CapitalContribution[]
  loans         Loan[]
  nonBankContribs NonBankContribution[]
  documents     ProjectDocument[]

  @@map("fin_project")
}

// ============================================================
// NÚCLEO: MOVIMIENTOS BANCARIOS
// ============================================================

model Movement {
  id              Int      @id @default(autoincrement())
  date            DateTime
  type            String
  amount          Float
  concept         String
  notes           String?

  accountId       Int
  account         Account  @relation("AccountFrom", fields: [accountId], references: [id])
  destAccountId   Int?
  destAccount     Account? @relation("AccountTo", fields: [destAccountId], references: [id])

  categoryId      Int?
  category        ExpenseCategory? @relation(fields: [categoryId], references: [id])
  originId        Int?
  origin          IncomeOrigin? @relation(fields: [originId], references: [id])
  providerId      Int?
  provider        Provider? @relation(fields: [providerId], references: [id])

  isEquity        Boolean  @default(false)
  partnerId       Int?
  partner         Partner? @relation(fields: [partnerId], references: [id])

  isLoan          Boolean  @default(false)
  lenderId        Int?
  lender          Lender?  @relation(fields: [lenderId], references: [id])
  isLoanRepayment Boolean  @default(false)
  loanId          Int?
  loan            Loan?    @relation(fields: [loanId], references: [id])

  projectId       Int?
  project         Project? @relation(fields: [projectId], references: [id])

  isIntercompany  Boolean  @default(false)
  linkedMovementId Int?    @unique
  linkedMovement   Movement? @relation("IntercompanyLink", fields: [linkedMovementId], references: [id])
  linkedFrom       Movement? @relation("IntercompanyLink")

  hasSupport      Boolean  @default(false)
  isReconciled    Boolean  @default(false)
  needsReview     Boolean  @default(false)
  reviewReason    String?

  importSource    String?
  importRef       String?

  documents       MovementDocument[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([accountId])
  @@index([projectId])
  @@index([partnerId])
  @@index([categoryId])
  @@index([type])
  @@map("fin_movement")
}

// ============================================================
// CAPITALIZACIÓN
// ============================================================

model CapitalContribution {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  concept     String
  origin      String
  partnerId   Int
  partner     Partner  @relation(fields: [partnerId], references: [id])
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id])
  destAccountCode String?
  notes       String?
  createdAt   DateTime @default(now())

  @@map("fin_capital_contribution")
}

model Loan {
  id            Int      @id @default(autoincrement())
  date          DateTime
  amount        Float
  concept       String
  lenderId      Int
  lender        Lender   @relation(fields: [lenderId], references: [id])
  projectId     Int?
  project       Project? @relation(fields: [projectId], references: [id])
  destAccountCode String?
  interestRate  Float?
  termMonths    Int?
  startDate     DateTime?
  endDate       DateTime?
  status        String   @default("activo")
  classification String?
  totalRepaid   Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  movements     Movement[]

  @@map("fin_loan")
}

model NonBankContribution {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  concept     String
  partnerId   Int
  partner     Partner  @relation(fields: [partnerId], references: [id])
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id])
  notes       String?
  createdAt   DateTime @default(now())

  @@map("fin_nonbank_contribution")
}

// ============================================================
// DOCUMENTOS / SOPORTES
// ============================================================

model MovementDocument {
  id          Int      @id @default(autoincrement())
  movementId  Int
  movement    Movement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  publicId    String?
  mimetype    String?
  size        Int?
  kind        String?
  uploadedAt  DateTime @default(now())

  @@map("fin_movement_document")
}

model ProjectDocument {
  id          Int      @id @default(autoincrement())
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  publicId    String?
  mimetype    String?
  size        Int?
  kind        String?
  uploadedAt  DateTime @default(now())

  @@map("fin_project_document")
}

// ============================================================
// EXTRACTOS BANCARIOS (RECONCILIACIÓN)
// ============================================================

model BankStatement {
  id          Int      @id @default(autoincrement())
  accountId   Int
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  openingBalance Float?
  closingBalance Float?
  filename    String?
  url         String?
  uploadedAt  DateTime @default(now())
  lines       BankStatementLine[]

  @@map("fin_bank_statement")
}

model BankStatementLine {
  id              Int      @id @default(autoincrement())
  statementId     Int
  statement       BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  date            DateTime
  description     String
  amount          Float
  type            String
  matchStatus     String   @default("unmatched")
  matchedMovementId Int?
  diffNote        String?

  @@map("fin_bank_statement_line")
}

// ============================================================
// AUDITORÍA / ALERTAS
// ============================================================

model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  detail    String?
  user      String?
  createdAt DateTime @default(now())

  @@map("fin_activity_log")
}
